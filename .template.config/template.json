{
  "$schema": "http://json.schemastore.org/template",
  "author": "DotNetTemplateClean",
  "classifications": [
    "Web",
    "API",
    "Angular"
  ],
  "name": "DotNet + Angular Full Stack Template",
  "description": "Reusable full stack template with a .NET backend and an Angular frontend. Backend is renamed from template name; frontend is copied unchanged.",
  "identity": "DotNetTemplateClean.FullStack",
  "shortName": "ca-angular",
  "sourceName": "DotNetTemplateClean",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "Database": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "sqlserver",
      "choices": [
        {
          "choice": "sqlserver",
          "description": "Use SQL Server provider"
        },
        {
          "choice": "postgresql",
          "description": "Use PostgreSQL provider"
        }
      ]
    },
    "UseSqlServer": {
      "type": "computed",
      "value": "(Database == \"sqlserver\")"
    },
    "UsePostgreSQL": {
      "type": "computed",
      "value": "(Database == \"postgresql\")"
    }
  },
  "sources": [
    {
      "source": "./",
      "target": "./",
      "exclude": [
		".git/**",
        ".github/**",
        "**/.git/**",
        "**/.github/**",
        "**/.vs/**",
		"**/.angular/**",
        ".template.config/**",
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
		"**/Migrations",
		"**/Migrations/**",
        "**/node_modules/**",
        "**/dist/**"
      ],
      "copyOnly": [
        "frontend/**"
      ]
    }
  ]
}
