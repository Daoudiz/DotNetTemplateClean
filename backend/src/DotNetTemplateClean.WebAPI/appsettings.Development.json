{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },

    "ApplicationInsights": {
        "ConnectionString": "InstrumentationKey=b3d3c0cd-3994-4c1c-9a23-11aa8646bad4;IngestionEndpoint=..."
    },

    "Serilog": {
        "MinimumLevel": {
            "Default": "Debug",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.AspNetCore": "Information", 
                "Microsoft.AspNetCore.Authentication": "Information", 
                "DotNETSampleArch": "Warning" 
            }
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "restrictedToMinimumLevel": "Warning", 
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} | User:{UserId} | Trace:{TraceId}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "restrictedToMinimumLevel": "Debug",
                    "path": "Logs/log-.txt",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 7,
                    "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
                }
            }
        ]
    },

    "ConnectionStrings": {
        "DBConnection": "YOUR_CONNECTION_STRING_HERE"
    },
    "Jwt": {
        "Key": "YOUR_SECRET_KEY_HERE",
        "Issuer": "",
        "Audience": "",
        "ExpiryMinutes": 120
    },

    "AllowedOrigins": [
        "http://localhost:4200",
        "https://localhost:4200"
    ],



    "SearchSettings": {
        "ThresholdForFullLoad": 500,
        "MaxPageSize": 100
    },

    "SeedData": {
        "EnableBogus": true
    }
}
